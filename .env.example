# Copia este archivo a .env y ajusta solo si hace falta.

# GEMINI (opcional)
# GEMINI_API_KEY=

# --- Expo / WebView ---
# Déjalo vacío o comenta la línea en desarrollo local:
# - Emulador Android: usa http://10.0.2.2:3000 automáticamente
# - Móvil físico (misma WiFi): usa la misma IP que Metro
# Solo con expo start --tunnel: necesitas una URL pública al puerto 3000 (p. ej. ngrok http 3000)
# EXPO_PUBLIC_WEB_APP_URL=

# EXPO_PUBLIC_WEB_APP_PORT=3000

# --- APK / Web empaquetada (file://): URL del servidor API en producción ---
# Obligatorio para que Social / login funcionen en el APK. Opciones:
# 1) Pon la misma URL en app.json → expo.extra.apiUrl (recomendado; se usa en prebuild y en la WebView)
# 2) O variable de entorno en EAS Build: EXPO_PUBLIC_API_URL
# Producción actual (AWS): ver app.json → extra.apiUrl y eas.json → EXPO_PUBLIC_API_URL
# EXPO_PUBLIC_API_URL=http://x.x.x.x:3000
# VITE_API_BASE_URL=http://x.x.x.x:3000
# --- Vercel (web en HTTPS; secundario frente a EAS/APK) ---
# vercel.json debe enrutar /api/* Y /health al backend (el login hace GET /health antes del login).
# No pongas en Vercel EXPO_PUBLIC_API_URL=http://IP si la web es HTTPS: el código fuerza mismo
# origen + proxy. EAS sigue usando eas.json → EXPO_PUBLIC_API_URL al APK (sin cambiar).
# Opción alternativa: API pública HTTPS y entonces VITE_API_BASE_URL=https://tu-api

# --- Vite: vacío = mismo origen que la página (recomendado con npm run dev y con Vercel+rewrite) ---
# VITE_API_BASE_URL=
