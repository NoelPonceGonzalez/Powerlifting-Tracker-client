{
  "expo": {
    "name": "Tracker",
    "slug": "powerlifting-tracker",
    "icon": "./assets/icon.png",
    "scheme": "powerliftingtracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.srhit.powerliftingtracker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.srhit.powerliftingtracker",
      "googleServicesFile": "./config/google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#334155",
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} notificaciones"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": true,
          "icon": "./assets/notification-icon.png",
          "color": "#334155"
        }
      ],
      "./plugins/withFirebaseAndroidSdk.cjs",
      "./plugins/withBundleWebApp.cjs",
      "./plugins/withAndroidCoreResolution.cjs",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "kotlinVersion": "2.1.20",
            "firebaseBomVersion": "33.6.0",
            "playServicesMeasurementVersion": "21.6.2"
          }
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "5a67afac-761c-4709-9665-9d85e9f1901c"
      },
      "apiUrl": "http://3.231.3.49:3000"
    },
    "owner": "noelponcegonzalez"
  }
}
