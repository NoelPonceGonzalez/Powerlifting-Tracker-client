{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "expo/AppEntry",
  "scripts": {
    "dev": "concurrently -k \"tsx server.ts\" \"wait-on http://localhost:3000 -t 30000 && npx expo start\" --names \"SERVER,EXPO\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail",
    "dev:server": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "expo": "node scripts/expo-cli-wrapper.cjs",
    "expo:start": "node scripts/expo-start-wrapper.cjs start",
    "expo:start:only": "expo start",
    "expo:android": "expo start --android",
    "expo:ios": "expo start --ios",
    "expo:tunnel": "expo start --tunnel",
    "start": "concurrently -k \"npm run dev:server\" \"wait-on http://localhost:3000 -t 30000 && npm run expo:start:only\" --names \"SERVER,EXPO\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail",
    "start:tunnel": "concurrently -k \"npm run dev:server\" \"wait-on http://localhost:3000 -t 30000 && npm run expo:tunnel\" --names \"SERVER,EXPO\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail",
    "tunnel:server": "node scripts/tunnel-server.cjs",
    "get-ip": "node scripts/get-local-ip.cjs",
    "postinstall": "patch-package && node scripts/setup-expo-alias.cjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express-session": "^1.18.2",
    "@types/react": "~19.0.10",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-preset-expo": "~13.0.0",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "expo": "^53.0.27",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-notifications": "~0.31.5",
    "expo-status-bar": "~2.2.0",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
